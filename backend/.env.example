# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tamangletra
ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tamangletra

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=False
ENVIRONMENT=development

# Translation API
TMT_API_TOKEN=team_ef9410e6b6bf70be
TMT_API_BASE_URL=https://tmt.ilprl.ku.edu.np/lang-translate

# Encryption
